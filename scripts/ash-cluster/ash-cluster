#!/usr/bin/env bash
# ash-cluster — One-command multi-node AI cluster controller
# Usage: ash-cluster up --nodes 3
#        ash-cluster down
#        ash-cluster status
#        ash-cluster logs [node]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$SCRIPT_DIR/.."
CLUSTER_DIR="$SCRIPT_DIR"
COMPOSE_FILE="$CLUSTER_DIR/docker-compose.yml"
CONSUL_DIR="$CLUSTER_DIR/consul"
NOMAD_DIR="$CLUSTER_DIR/nomad"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'
log() { echo -e "${GREEN}[+]${NC} $*"; }
err() { echo -e "${RED}[✗]${NC} $*" >&2; }
info() { echo -e "${CYAN}[i]${NC} $*"; }

NODE_COUNT=3
ORCHESTRATOR="docker-compose"
CLOUD=""

usage() {
  cat <<'USAGE'
ash-cluster — Multi-node AI cluster controller

Usage:
  ash-cluster up --nodes N [--orchestrator docker|nomad] [--cloud aws|gcp|azure]
  ash-cluster down
  ash-cluster status
  ash-cluster logs [node]
  ash-cluster ps

Examples:
  ash-cluster up --nodes 3
  ash-cluster up --nodes 5 --orchestrator nomad
  ash-cluster down
USAGE
  exit 0
}

gen_compose() {
  log "Generating Docker Compose with $NODE_COUNT nodes..."
  cat > "$COMPOSE_FILE" << COMPOSE_HEADER
# ash-cluster docker-compose.yml — Auto-generated
# Nodes: $NODE_COUNT | Generated: $(date -u +%Y-%m-%dT%H:%M:%SZ)

volumes:
  qdrant_data:
  ollama_cache:

networks:
  ash-cluster:
    driver: bridge
    ipam:
      config:
        - subnet: 172.20.0.0/16

services:
  consul:
    image: hashicorp/consul:latest
    hostname: consul
    container_name: ash-consul
    networks:
      ash-cluster:
        ipv4_address: 172.20.0.2
    ports:
      - "8300:8300"
      - "8500:8500"
      - "8600:8600/udp"
    command: agent -server -bootstrap-expect=1 -ui -client=0.0.0.0 -bind=0.0.0.0
    healthcheck:
      test: ["CMD", "consul", "info"]
      interval: 10s
      retries: 5

  qdrant:
    image: qdrant/qdrant:latest
    hostname: qdrant
    container_name: ash-qdrant
    networks:
      ash-cluster:
        ipv4_address: 172.20.0.3
    ports:
      - "6333:6333"
      - "6334:6334"
    volumes:
      - qdrant_data:/qdrant/storage
    environment:
      QDRANT__SERVICE__GRPC_PORT: 6334
      QDRANT__CLUSTER__ENABLED: "true"
      QDRANT__CLUSTER__CONSENSUS_DATA_PATH: /qdrant/storage/consensus
    command: ["qdrant", "--uri", "http://qdrant:6335"]
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:6333/healthz"]
      interval: 15s
      retries: 10
      start_period: 10s

  router:
    image: nginx:alpine
    hostname: router
    container_name: ash-router
    networks:
      ash-cluster:
        ipv4_address: 172.20.0.4
    ports:
      - "80:80"
      - "443:443"
      - "11434:11434"
    volumes:
      - $CLUSTER_DIR/nginx-router.conf:/etc/nginx/conf.d/default.conf:ro
    depends_on:
      consul:
        condition: service_started
    healthcheck:
      test: ["CMD", "nginx", "-t"]
      interval: 30s
      retries: 3

COMPOSE_HEADER

  # Generate N worker nodes
  for i in $(seq 1 "$NODE_COUNT"); do
    local ip=$(( 4 + i ))
    cat >> "$COMPOSE_FILE" << NODE_CONFIG
  ollama-node-$i:
    image: ollama/ollama:latest
    hostname: ollama-node-$i
    container_name: ash-ollama-node-$i
    networks:
      ash-cluster:
        ipv4_address: 172.20.0.$ip
    volumes:
      - ollama_cache:/root/.ollama
    environment:
      OLLAMA_HOST: 0.0.0.0
      OLLAMA_ORIGINS: "*"
      OLLAMA_NUM_PARALLEL: "4"
      OLLAMA_KEEP_ALIVE: "5m"
      OLLAMA_DISABLE_LOADING: "false"
      CONSUL_HTTP_ADDR: "172.20.0.2:8500"
      NODE_ID: "node-$i"
    deploy:
      resources:
        limits:
          cpus: '${{ i * 2 }}'
          memory: '${i * 4}G'
        reservations:
          cpus: '1'
          memory: '2G'
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:11434/api/tags"]
      interval: 30s
      retries: 5
      start_period: 20s

NODE_CONFIG
  done

  # Traefik for load balancing
  cat >> "$COMPOSE_FILE" << 'TRAEFIK'
  traefik:
    image: traefik:v3.1
    hostname: traefik
    container_name: ash-traefik
    networks:
      ash-cluster:
        ipv4_address: 172.20.0.100
    ports:
      - "8080:8080"
    command:
      - "--providers.consulCatalog=true"
      - "--providers.consulCatalog.endpoint.address=172.20.0.2:8500"
      - "--providers.consulCatalog.prefix=traefik"
      - "--api.dashboard=true"
      - "--api.insecure=true"
      - "--entrypoints.web.address=:80"
      - "--entrypoints.ollama.address=:11434"
      - "--log.level=INFO"
    depends_on:
      consul:
        condition: service_started
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:8080/ping"]
      interval: 15s
      retries: 5
TRAEFIK

  log "Compose file generated at $COMPOSE_FILE"
}

gen_nginx_router() {
  mkdir -p "$CLUSTER_DIR"
  cat > "$CLUSTER_DIR/nginx-router.conf" << 'NGINX'
upstream ollama_backend {
    least_conn;
    server ollama-node-1:11434 max_fails=3 fail_timeout=30s;
}

upstream qdrant_backend {
    least_conn;
    server qdrant:6333 max_fails=3 fail_timeout=30s;
}

server {
    listen 80;
    server_name _;

    location /api/generate {
        proxy_pass http://ollama_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }

    location /api/chat {
        proxy_pass http://ollama_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }

    location /v1/ {
        proxy_pass http://ollama_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 300s;
    }

    location /qdrant/ {
        proxy_pass http://qdrant_backend/;
        proxy_set_header Host $host;
    }

    location /health {
        return 200 "OK\n";
        add_header Content-Type text/plain;
    }

    location / {
        root /usr/share/nginx/html;
        index index.html;
    }
}
NGINX
}

gen_nomad() {
  log "Generating Nomad job spec with $NODE_COUNT nodes..."
  mkdir -p "$NOMAD_DIR"

  cat > "$NOMAD_DIR/ash-cluster.nomad" << NOMAD
# ash-cluster Nomad Job Specification
job "ash-cluster" {
  datacenters = ["dc1"]
  type        = "service"

  group "qdrant" {
    count = 1
    network {
      port "http" { to = 6333 }
      port "grpc" { to = 6334 }
    }
    task "qdrant" {
      driver = "docker"
      config {
        image = "qdrant/qdrant:latest"
        ports = ["http", "grpc"]
      }
      resources {
        cpu    = 2000
        memory = 2048
      }
    }
    restart {
      attempts = 3
      delay    = "30s"
    }
  }

  group "ollama" {
    count = $NODE_COUNT
    network {
      port "ollama" { to = 11434 }
    }
    task "ollama" {
      driver = "docker"
      config {
        image = "ollama/ollama:latest"
        ports = ["ollama"]
        environment = {
          OLLAMA_HOST = "0.0.0.0"
          OLLAMA_NUM_PARALLEL = "4"
        }
      }
      resources {
        cpu    = 4000
        memory = 8192
      }
    }
  }

  group "router" {
    count = 1
    network {
      port "http" { to = 80 }
    }
    task "router" {
      driver = "docker"
      config {
        image = "nginx:alpine"
        ports = ["http"]
      }
      resources {
        cpu    = 500
        memory = 256
      }
    }
  }
}
NOMAD
  log "Nomad job spec generated at $NOMAD_DIR/ash-cluster.nomad"
}

up() {
  log "Starting ash cluster with $NODE_COUNT nodes..."

  case "$ORCHESTRATOR" in
    docker-compose|docker)
      gen_compose
      gen_nginx_router
      log "Starting containers..."
      docker compose -f "$COMPOSE_FILE" up -d --remove-orphans
      log "Waiting for cluster readiness..."
      sleep 10
      docker compose -f "$COMPOSE_FILE" ps
      ;;

    nomad)
      gen_nomad
      log "Submitting Nomad job..."
      nomad job run "$NOMAD_DIR/ash-cluster.nomad"
      log "Waiting for allocation..."
      sleep 10
      nomad job status ash-cluster
      ;;

    *)
      err "Unknown orchestrator: $ORCHESTRATOR"
      exit 1
      ;;
  esac

  # Register services with Consul
  if command -v consul &>/dev/null; then
    for i in $(seq 1 "$NODE_COUNT"); do
      consul services register \
        -name "ollama-node-$i" \
        -port 11434 \
        -address "ollama-node-$i" &
    done
    wait
  fi

  # Save cluster state
  mkdir -p /tmp/ash-cluster
  echo "$NODE_COUNT" > /tmp/ash-cluster/node-count
  echo "$ORCHESTRATOR" > /tmp/ash-cluster/orchestrator
  date -u +%Y-%m-%dT%H:%M:%SZ > /tmp/ash-cluster/started-at

  log "Cluster is ready!"
  echo ""
  info "  Router:      http://localhost:80"
  info "  Ollama API:  http://localhost:11434"
  info "  Qdrant:      http://localhost:6333"
  info "  Consul UI:   http://localhost:8500"
  info "  Traefik:     http://localhost:8080"
  echo ""
  info "  Pull a model on any node:"
  info "    docker exec ash-ollama-node-1 ollama pull llama3.2"
  echo ""
}

down() {
  log "Tearing down ash cluster..."

  if [[ -f "$COMPOSE_FILE" ]]; then
    docker compose -f "$COMPOSE_FILE" down -v --remove-orphans 2>/dev/null || true
  fi

  docker rm -f $(docker ps -aq --filter "name=ash-") 2>/dev/null || true
  docker network rm ash-cluster 2>/dev/null || true

  if command -v nomad &>/dev/null; then
    nomad job stop -purge ash-cluster 2>/dev/null || true
  fi

  rm -f /tmp/ash-cluster/node-count /tmp/ash-cluster/orchestrator /tmp/ash-cluster/started-at
  log "Cluster torn down"
}

status() {
  echo "=== ash Cluster Status ==="
  echo ""

  if [[ -f /tmp/ash-cluster/node-count ]]; then
    echo "Nodes:  $(cat /tmp/ash-cluster/node-count)"
    echo "Started: $(cat /tmp/ash-cluster/started-at 2>/dev/null || echo 'unknown')"
    echo "Orchestrator: $(cat /tmp/ash-cluster/orchestrator 2>/dev/null || echo 'unknown')"
    echo ""
  fi

  docker compose -f "$COMPOSE_FILE" ps 2>/dev/null || echo "Cluster not running"
}

cluster_logs() {
  local node="${1:-}"
  if [[ -n "$node" ]]; then
    docker logs "ash-ollama-$node" -f 2>/dev/null || err "Node $node not found"
  else
    docker compose -f "$COMPOSE_FILE" logs -f 2>/dev/null || err "Cluster not running"
  fi
}

cluster_ps() {
  docker ps --filter "name=ash-" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || echo "No cluster containers running"
}

main() {
  [[ $# -eq 0 ]] && usage

  case "${1:-}" in
    up)
      shift
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --nodes) NODE_COUNT="${2:-3}"; shift 2 ;;
          --orchestrator) ORCHESTRATOR="$2"; shift 2 ;;
          --cloud) CLOUD="$2"; shift 2 ;;
          --help) usage ;;
          *) shift ;;
        esac
      done
      up
      ;;
    down) down ;;
    status) status ;;
    logs) cluster_logs "${2:-}" ;;
    ps) cluster_ps ;;
    --help|help) usage ;;
    *) err "Unknown command: $1"; usage ;;
  esac
}

main "$@"
