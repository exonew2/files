---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const docs = await getCollection('docs');
docs.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---
<Layout
  title="Documentation — ash ISO"
  description="Quick start, GPU passthrough, persistence, updates, comparison — full documentation for ash Arch Snapshot Hypervisor."
  ogImage="/og-image.svg"
>
<section class="page-hero">
  <div class="container">
    <h1>Documentation</h1>
    <p class="lead">Everything you need to use ash ISO — from boot to deployment.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="docs-grid">
      {
        docs.map((doc) => (
          <a href={`/docs/${doc.slug}`} class="docs-card">
            <h3>{doc.data.title}</h3>
            <p>{doc.data.description}</p>
            <span class="docs-link">Read →</span>
          </a>
        ))
      }
    </div>
  </div>
</section>
</Layout>

<style>
.docs-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 24px;
  max-width: 1000px;
  margin: 0 auto;
}
.docs-card {
  display: block;
  padding: 28px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  text-decoration: none;
  transition: box-shadow 0.2s, border-color 0.2s;
}
.docs-card:hover {
  border-color: var(--brand);
  box-shadow: var(--shadow-lg);
}
.docs-card h3 {
  font-size: 18px;
  font-weight: 700;
  margin-bottom: 8px;
  color: var(--text);
}
.docs-card p {
  font-size: 14px;
  color: var(--text-dim);
  line-height: 1.6;
  margin-bottom: 12px;
}
.docs-link {
  font-size: 14px;
  font-weight: 600;
  color: var(--brand);
}
</style>
