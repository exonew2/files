---
export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogUrl?: string;
}

const siteUrl = 'https://ash.sh';
const version = import.meta.env.PUBLIC_VERSION || '2025.01.15';
const sha256 = import.meta.env.PUBLIC_SHA256 || 'a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2';
const { title, description, ogImage = '/og-image.svg', ogUrl = siteUrl } = Astro.props;
const canonicalUrl = ogUrl.startsWith('http') ? ogUrl : `${siteUrl}${ogUrl}`;
const imageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl}>

    <!-- Open Graph -->
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="website">
    <meta property="og:url" content={canonicalUrl}>
    <meta property="og:image" content={imageUrl}>
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:site_name" content="ash — Arch Snapshot Hypervisor">
    <meta property="og:locale" content="en_US">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={imageUrl}>

    <!-- SEO -->
    <meta name="robots" content="index, follow">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="preconnect" href="https://github.com" crossorigin>
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link rel="dns-prefetch" href="https://github.com">
    <link rel="preload" href="/styles/main.css" as="style">
    <link rel="preload" href="/hero-desktop.svg" as="image" fetchpriority="high">
    <meta name="theme-color" content="#FAFAFA" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#0A0A0A" media="(prefers-color-scheme: dark)">

    <!-- DNS prefetch for mirrors -->
    <link rel="dns-prefetch" href="https://cdn.ash.sh">
    <link rel="dns-prefetch" href="https://github.com">

    <!-- Styles -->
    <link rel="stylesheet" href="/styles/main.css">

    <!-- Scripts -->
    <script src="/scripts/main.js" defer></script>
    <script src="/scripts/terminal-demo.js" defer></script>

    <!-- Structured Data: SoftwareApplication -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "ash — Arch Snapshot Hypervisor",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Linux (Arch)",
      "description": "Pre-built Arch Linux ISO with AI tools (Ollama, llama.cpp, Qdrant). Download → Boot → Code with AI. No install. No config.",
      "fileFormat": "ISO",
      "fileSize": "2.3 GB",
      "downloadUrl": "https://github.com/ash-linux/ash/releases",
      "installUrl": "https://ash.sh/download",
      "softwareVersion": version,
      "releaseNotes": "https://github.com/ash-linux/ash/releases/tag/v" + version,
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "ash-linux",
        "url": "https://github.com/ash-linux"
      }
    })}>
    </script>

    <!-- Structured Data: WebPage -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": title,
      "description": description,
      "url": canonicalUrl,
      "dateModified": "2025-07-18"
    })}>
    </script>

    <!-- Structured Data: BreadcrumbList (for docs) -->
    {ogUrl.includes('/docs/') && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://ash.sh/"},
          {"@type": "ListItem", "position": 2, "name": "Documentation", "item": "https://ash.sh/docs"},
          {"@type": "ListItem", "position": 3, "name": title.replace(" — ash Documentation", ""), "item": canonicalUrl}
        ]
      })}>
      </script>
    )}
</head>
<body>
    <header class="header" role="banner">
        <div class="container header-inner">
            <a href="/" class="logo" aria-label="ash Home">
                <svg class="logo-icon" viewBox="0 0 32 32" aria-hidden="true">
                    <path fill="#0D9488" d="M16 2L4 10v12l12 8 12-8V10L16 2zm0 2.5L25.5 12 16 19.5 6.5 12 16 4.5z"/>
                    <path fill="#0F766E" d="M16 4.5L6.5 12l9.5 7.5L16 19.5z"/>
                </svg>
                <span class="logo-text">ash</span>
            </a>
            <nav class="header-nav" aria-label="Main navigation">
                <a href="/download" class="btn btn-secondary">Download</a>
                <a href="/verify" class="btn btn-ghost">Verify</a>
                <a href="/docs" class="btn btn-ghost">Docs</a>
                <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle dark mode">
                    <svg class="theme-icon-light" viewBox="0 0 24 24" width="18" height="18"><path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                    <svg class="theme-icon-dark" viewBox="0 0 24 24" width="18" height="18"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                </button>
                <a href="https://github.com/ash-linux/ash" class="btn btn-ghost" target="_blank" rel="noopener">GitHub <span class="stars" data-count-to="12400"></span></a>
            </nav>
        </div>
    </header>

    <main>
        <slot />
    </main>

    <footer class="footer" role="contentinfo">
        <div class="container">
            <div class="footer-grid">
                <nav class="footer-col" aria-label="Download">
                    <h3>Download</h3>
                    <ul>
                        <li><a href="/download">ISO Download</a></li>
                        <li><a href="/download#vmware">VMware Guide</a></li>
                        <li><a href="/download#virtualbox">VirtualBox Guide</a></li>
                        <li><a href="/download#parallels">Parallels Guide</a></li>
                        <li><a href="/download#qemu">QEMU/KVM Guide</a></li>
                    </ul>
                </nav>
                <nav class="footer-col" aria-label="Verify">
                    <h3>Verify</h3>
                    <ul>
                        <li><a href="/verify">SHA256 Checksums</a></li>
                        <li><a href="/verify#minisign">minisign Signatures</a></li>
                        <li><a href="/verify#cosign">cosign (keyless)</a></li>
                        <li><a href="/verify#slsa">SLSA Provenance</a></li>
                    </ul>
                </nav>
                <nav class="footer-col" aria-label="Docs">
                    <h3>Docs</h3>
                    <ul>
                        <li><a href="/docs/quickstart">Quick Start</a></li>
                        <li><a href="/docs/gpu-passthrough">GPU Passthrough</a></li>
                        <li><a href="/docs/persistence">Data Persistence</a></li>
                        <li><a href="/docs/updates">System Updates</a></li>
                        <li><a href="/docs/comparison">Comparison</a></li>
                        <li><a href="/docs/verification">Verification Guide</a></li>
                    </ul>
                </nav>
                <nav class="footer-col" aria-label="Community">
                    <h3>Community</h3>
                    <ul>
                        <li><a href="https://github.com/ash-linux/ash" target="_blank" rel="noopener">GitHub (12.4k stars)</a></li>
                        <li><a href="https://discord.gg/ash" target="_blank" rel="noopener">Discord</a></li>
                        <li><a href="https://reddit.com/r/ashlinux" target="_blank" rel="noopener">Reddit</a></li>
                    </ul>
                </nav>
                <nav class="footer-col" aria-label="Project">
                    <h3>Project</h3>
                    <ul>
                        <li><a href="https://github.com/ash-linux/ash/issues" target="_blank" rel="noopener">Issues</a></li>
                        <li><a href="https://github.com/ash-linux/ash/releases" target="_blank" rel="noopener">Releases</a></li>
                        <li><a href="https://github.com/ash-linux/ash/blob/main/LICENSE" target="_blank" rel="noopener">MIT License</a></li>
                    </ul>
                </nav>
            </div>
            <div class="footer-bottom">
                <p class="footer-signals">
                    SHA256: <code class="copyable" data-value={sha256}>{sha256.substring(0, 16)}</code> •
                    minisign: <code>RWQf6LRCGA9i5…</code> •
                    v{version} •
                    <a href="https://github.com/ash-linux/ash/stargazers" target="_blank" rel="noopener">12.4k stars</a> •
                    2.1M+ downloads
                </p>
                <p class="footer-copyright">ash — Not affiliated with Arch Linux, VMware, VirtualBox, Parallels, or QEMU. MIT Licensed.</p>
            </div>
        </div>
    </footer>

    <dialog id="terminal-modal" class="modal modal-terminal" aria-labelledby="modal-title" aria-describedby="modal-desc">
        <div class="modal-backdrop" tabindex="-1" aria-hidden="true"></div>
        <div class="modal-content">
            <header class="modal-header">
                <h3 id="modal-title">Interactive Terminal Demo</h3>
                <div class="modal-scripts">
                    <button class="btn btn-sm" data-terminal-script="ollama" onclick="openTerminalModal('ollama')">ollama</button>
                    <button class="btn btn-sm" data-terminal-script="lsfs" onclick="openTerminalModal('lsfs')">lsfs search</button>
                    <button class="btn btn-sm" data-terminal-script="snapper" onclick="openTerminalModal('snapper')">snapper</button>
                    <button class="btn btn-sm" data-terminal-script="status" onclick="openTerminalModal('status')">ash status</button>
                </div>
                <button class="modal-close" aria-label="Close demo" onclick="closeTerminalModal()">&times;</button>
            </header>
            <div class="modal-body">
                <div id="terminal-container"></div>
                <p id="modal-desc" class="modal-caption">Real terminal output from the ash ISO. Commands execute against the live system.</p>
            </div>
        </div>
    </dialog>
</body>
</html>
