{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "cssPriority": "application",
  "control-center-margin-top": 8,
  "control-center-margin-bottom": 8,
  "control-center-margin-right": 8,
  "control-center-margin-left": 8,
  "notification-placement": "top-right",
  "notification-icon-size": 48,
  "notification-body-image-height": 192,
  "notification-body-image-width": 384,
  "timeout": 8,
  "timeout-low": 5,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "control-center-width": 420,
  "control-center-height": 680,
  "notification-window-width": 380,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-filters": [
    {
      "name": "ai-summarize",
      "script": "/usr/lib/ash-desktop/swaync-ai-summarize.sh"
    }
  ],
  "notification-visibility": {
    "example-low-sound": {
      "state": "muted",
      "urgency": "Low",
      "app-name": ".*"
    }
  },
  "widgets": [
    "inhibitors",
    "title",
    "dnd",
    "mpris",
    "notifications"
  ],
  "widget-config": {
    "inhibitors": {
      "text": "Inhibitors",
      "button-text": "Clear All",
      "clear-all-button": true
    },
    "title": {
      "text": "Ash Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "label": {
      "max-lines": 6,
      "text": "Notification Center"
    },
    "mpris": {
      "image-size": 96,
      "image-radius": 8
    },
    "notifications": {
      "clear-all-button": true,
      "background": "rgba(30, 30, 46, 0.9)"
    }
  }
}
