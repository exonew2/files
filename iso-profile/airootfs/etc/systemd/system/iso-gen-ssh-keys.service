[Unit]
Description=Generate SSH Host and User Keys
DefaultDependencies=no
After=systemd-remount-fs.service systemd-sysusers.service
Before=sshd.socket sshd.service iso-firstboot.service
ConditionPathExists=!/etc/ssh/ssh_host_ed25519_key

[Service]
Type=oneshot
ExecStart=/usr/lib/iso/gen-ssh-keys.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
