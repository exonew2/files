#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'

VERSION="1.0.0"
REPORT_FILE="/tmp/ash-doctor-report-$(date +%Y%m%d-%H%M%S).md"
PASS=0
FAIL=0
WARN=0

usage() {
    cat <<EOF
ash-doctor вЂ” Comprehensive System Diagnostic v${VERSION}

Usage:
  ash-doctor check           Full system health check
  ash-doctor check --boot    Boot performance analysis
  ash-doctor check --net     Network diagnostics
  ash-doctor check --ai      AI stack health
  ash-doctor fix             Auto-fix detected issues
  ash-doctor report          Generate diagnostic report
  ash-doctor help            Show this help
EOF
    exit 0
}

check() {
    echo -e "${CYAN}в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${NC}"
    echo -e "${CYAN}в•‘     ash System Health Check          в•‘${NC}"
    echo -e "${CYAN}в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${NC}"
    echo ""

    case "${1:-}" in
        --boot) check_boot ;;
        --net)  check_net ;;
        --ai)   check_ai ;;
        *)      check_all ;;
    esac

    echo ""
    echo -e "${BLUE}Results: ${GREEN}${PASS} passed${NC}, ${RED}${FAIL} failed${NC}, ${YELLOW}${WARN} warnings${NC}"
    [[ $FAIL -eq 0 ]] && echo -e "${GREEN}System health: OK${NC}" || echo -e "${RED}System health: ISSUES DETECTED${NC}"
}

check_boot() {
    echo -e "${BLUE}[Boot Analysis]${NC}"
    local c
    c=$((PASS+FAIL+WARN))

    if command -v systemd-analyze &>/dev/null; then
        echo -e "  systemd-analyze:"
        systemd-analyze 2>/dev/null | sed 's/^/    /'
        systemd-analyze blame 2>/dev/null | head -10 | sed 's/^/    /'
        PASS=$((PASS+1))
    else
        WARN=$((WARN+1)); echo -e "  ${YELLOW}systemd-analyze not available${NC}"
    fi

    if command -v dmesg &>/dev/null; then
        local errors
        errors=$(dmesg -l err,crit,alert,emerg 2>/dev/null | wc -l)
        echo -e "  Kernel errors: ${errors}"
        [[ $errors -gt 10 ]] && { FAIL=$((FAIL+1)); echo -e "  ${RED}High kernel error count${NC}"; } || { PASS=$((PASS+1)); echo -e "  ${GREEN}OK${NC}"; }
    fi

    [[ $((PASS+FAIL+WARN)) -eq $c ]] && WARN=$((WARN+1))
}

check_net() {
    echo -e "${BLUE}[Network Diagnostics]${NC}"
    local c
    c=$((PASS+FAIL+WARN))

    echo -e "  Interface:"
    ip -br addr 2>/dev/null | sed 's/^/    /' || true

    if ping -c 1 -W 2 8.8.8.8 &>/dev/null; then
        echo -e "  ${GREEN}Internet: Connected${NC}"; PASS=$((PASS+1))
    else
        echo -e "  ${RED}Internet: No connectivity${NC}"; FAIL=$((FAIL+1))
    fi

    if systemctl is-active --quiet NetworkManager 2>/dev/null || systemctl is-active --quiet systemd-networkd 2>/dev/null; then
        echo -e "  ${GREEN}Network manager: Active${NC}"; PASS=$((PASS+1))
    else
        echo -e "  ${RED}No network manager running${NC}"; FAIL=$((FAIL+1))
    fi

    if command -v firewall-cmd &>/dev/null; then
        local zone
        zone=$(firewall-cmd --get-default-zone 2>/dev/null || echo "unknown")
        echo -e "  Firewall zone: ${zone}"; PASS=$((PASS+1))
    else
        WARN=$((WARN+1)); echo -e "  ${YELLOW}firewalld not available${NC}"
    fi

    [[ $((PASS+FAIL+WARN)) -eq $c ]] && WARN=$((WARN+1))
}

check_ai() {
    echo -e "${BLUE}[AI Stack Health]${NC}"
    local c
    c=$((PASS+FAIL+WARN))

    # Ollama
    if command -v ollama &>/dev/null; then
        if ollama list &>/dev/null 2>&1; then
            echo -e "  ${GREEN}Ollama: Running${NC}"; PASS=$((PASS+1))
            echo -e "  Models:"
            ollama list 2>/dev/null | sed 's/^/    /'
        else
            echo -e "  ${YELLOW}Ollama: Installed but not running${NC}"; WARN=$((WARN+1))
        fi
    else
        echo -e "  ${YELLOW}Ollama: Not installed${NC}"; WARN=$((WARN+1))
    fi

    # Qdrant
    if command -v qdrant &>/dev/null || systemctl list-unit-files qdrant.service &>/dev/null 2>&1; then
        if curl -s http://localhost:6333/health &>/dev/null; then
            echo -e "  ${GREEN}Qdrant: Responding on :6333${NC}"; PASS=$((PASS+1))
        else
            echo -e "  ${YELLOW}Qdrant: Installed but not responding${NC}"; WARN=$((WARN+1))
        fi
    else
        echo -e "  ${YELLOW}Qdrant: Not installed${NC}"; WARN=$((WARN+1))
    fi

    # Nvidia GPU for AI
    if command -v nvidia-smi &>/dev/null; then
        echo -e "  ${GREEN}NVIDIA GPU detected${NC}"
        nvidia-smi --query-gpu=name,temperature.gpu,memory.used,memory.total --format=csv,noheader 2>/dev/null | sed 's/^/    /'
        PASS=$((PASS+1))
    fi

    [[ $((PASS+FAIL+WARN)) -eq $c ]] && WARN=$((WARN+1))
}

check_all() {
    local c
    c=$((PASS+FAIL+WARN))

    # в”Ђв”Ђ System Info в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    echo -e "${BLUE}[System]${NC}"
    echo -e "  Hostname: $(hostname)"
    echo -e "  Kernel: $(uname -r)"
    echo -e "  Uptime: $(uptime -p 2>/dev/null || uptime)"
    echo -e "  Load: $(cat /proc/loadavg 2>/dev/null | cut -d' ' -f1-3)"
    PASS=$((PASS+1))

    # в”Ђв”Ђ CPU в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    echo -e "${BLUE}[CPU]${NC}"
    local cpu_count
    cpu_count=$(nproc 2>/dev/null || echo "?")
    echo -e "  Cores: ${cpu_count}"
    local cpu_model
    cpu_model=$(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | cut -d: -f2 | sed 's/^ *//' || echo "unknown")
    echo -e "  Model: ${cpu_model}"
    PASS=$((PASS+1))

    # в”Ђв”Ђ Memory в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    echo -e "${BLUE}[Memory]${NC}"
    free -h 2>/dev/null | sed 's/^/  /' || true
    local mem_avail_pct
    mem_avail_pct=$(free | awk '/^Mem:/ {printf "%.0f", $7/$2 * 100}' 2>/dev/null || echo 0)
    if [[ $mem_avail_pct -lt 10 ]]; then
        echo -e "  ${RED}Critical: Only ${mem_avail_pct}% memory available${NC}"; FAIL=$((FAIL+1))
    else
        PASS=$((PASS+1))
    fi

    # в”Ђв”Ђ Disk в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    echo -e "${BLUE}[Disk]${NC}"
    df -h / 2>/dev/null | sed 's/^/  /' || true
    local disk_avail_pct
    disk_avail_pct=$(df / | awk 'NR==2 {printf "%.0f", $4/$2 * 100}' 2>/dev/null || echo 0)
    if [[ $disk_avail_pct -lt 10 ]]; then
        echo -e "  ${RED}Critical: Only ${disk_avail_pct}% disk space available${NC}"; FAIL=$((FAIL+1))
    else
        PASS=$((PASS+1))
    fi

    if command -v btrfs &>/dev/null; then
        echo -e "  ${GREEN}Btrfs detected${NC}"
        btrfs filesystem show / 2>/dev/null | sed 's/^/    /' || true
        btrfs scrub status / 2>/dev/null | sed 's/^/    /' || true
        PASS=$((PASS+1))
    fi

    # в”Ђв”Ђ GPU в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    echo -e "${BLUE}[GPU]${NC}"
    if command -v nvidia-smi &>/dev/null; then
        echo -e "  ${GREEN}NVIDIA:${NC}"
        nvidia-smi --query-gpu=name,temperature.gpu,memory.used,memory.total --format=csv,noheader 2>/dev/null | sed 's/^/    /'
        PASS=$((PASS+1))
    fi
    if command -v vulkaninfo &>/dev/null; then
        echo -e "  ${GREEN}Vulkan: Available${NC}"; PASS=$((PASS+1))
    else
        WARN=$((WARN+1)); echo -e "  ${YELLOW}Vulkan: Not available${NC}"
    fi

    # в”Ђв”Ђ Packages в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    echo -e "${BLUE}[Package Integrity]${NC}"
    if command -v pacman &>/dev/null; then
        local broken
        broken=$(pacman -Qk 2>/dev/null | grep -c 'WARNING' || true)
        if [[ $broken -eq 0 ]]; then
            echo -e "  ${GREEN}All packages intact${NC}"; PASS=$((PASS+1))
        else
            echo -e "  ${YELLOW}${broken} packages with warnings${NC}"; WARN=$((WARN+1))
        fi
    fi

    # в”Ђв”Ђ Security в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    echo -e "${BLUE}[Security]${NC}"
    if systemctl is-active --quiet firewalld 2>/dev/null; then
        echo -e "  ${GREEN}Firewalld: Active${NC}"; PASS=$((PASS+1))
    else
        WARN=$((WARN+1)); echo -e "  ${YELLOW}Firewalld: Not active${NC}"
    fi
    if systemctl is-active --quiet sshd.socket 2>/dev/null || systemctl is-active --quiet sshd 2>/dev/null; then
        echo -e "  ${YELLOW}SSH: Active${NC}"; WARN=$((WARN+1))
    else
        PASS=$((PASS+1))
    fi

    # в”Ђв”Ђ AI Stack в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    check_ai

    # в”Ђв”Ђ Boot в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    check_boot

    # в”Ђв”Ђ Network в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    check_net

    [[ $((PASS+FAIL+WARN)) -eq $c ]] && WARN=$((WARN+1))
}

cmd_fix() {
    echo -e "${BLUE}Attempting auto-fix...${NC}"

    # Fix pacman keyring
    if ! pacman -Qk 2>/dev/null | grep -q 'WARNING'; then
        echo -e "  ${GREEN}Pacman: OK${NC}"
    else
        echo -e "  ${YELLOW}Reinitializing pacman keyring...${NC}"
        sudo rm -rf /etc/pacman.d/gnupg
        sudo pacman-key --init
        sudo pacman-key --populate archlinux
        echo -e "  ${GREEN}Keyring reinitialized${NC}"
    fi

    # Fix systemd services
    local failed
    failed=$(systemctl --failed --no-legend 2>/dev/null | awk '{print $1}')
    if [[ -n "$failed" ]]; then
        echo -e "  ${YELLOW}Failed services: $failed${NC}"
        for svc in $failed; do
            sudo systemctl reset-failed "$svc" 2>/dev/null || true
            sudo systemctl restart "$svc" 2>/dev/null || true
        done
        echo -e "  ${GREEN}Attempted restart${NC}"
    fi

    # Fix DNS
    if ! ping -c 1 -W 2 8.8.8.8 &>/dev/null; then
        echo -e "  ${YELLOW}Restarting network...${NC}"
        sudo systemctl restart NetworkManager 2>/dev/null || sudo systemctl restart systemd-networkd 2>/dev/null || true
    fi

    echo -e "${GREEN}Auto-fix complete вЂ” run 'ash-doctor check' to verify${NC}"
}

cmd_report() {
    echo -e "${BLUE}Generating diagnostic report...${NC}"
    {
        echo "# ash Doctor Report"
        echo "Generated: $(date -u)"
        echo ""
        echo "## System"
        echo "- Hostname: $(hostname)"
        echo "- Kernel: $(uname -r)"
        echo "- Uptime: $(uptime -p 2>/dev/null || uptime)"
        echo ""
        echo "## CPU"
        echo "- Cores: $(nproc 2>/dev/null || echo '?')"
        echo "- Model: $(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | cut -d: -f2 | sed 's/^ *//' || echo 'unknown')"
        echo ""
        echo "## Memory"
        free -h 2>/dev/null || true
        echo ""
        echo "## Disk"
        df -h / 2>/dev/null || true
        echo ""
        echo "## GPU"
        nvidia-smi --query-gpu=name,temperature.gpu,memory.used,memory.total --format=csv,noheader 2>/dev/null || echo "No NVIDIA GPU"
        echo ""
        echo "## Network"
        ip -br addr 2>/dev/null || true
        echo ""
        echo "## Services"
        systemctl list-units --state=failed --no-legend 2>/dev/null || echo "None"
    } > "$REPORT_FILE"
    echo -e "${GREEN}Report saved: ${CYAN}${REPORT_FILE}${NC}"
}

# в”Ђв”Ђв”Ђ CLI в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
[[ $# -eq 0 ]] && { usage; exit 0; }

case "$1" in
    check)  shift; check "${1:-}" ;;
    fix)    cmd_fix ;;
    report) cmd_report ;;
    help|-h) usage ;;
    *)      echo -e "${RED}Unknown command: $1${NC}"; usage; exit 1 ;;
esac
