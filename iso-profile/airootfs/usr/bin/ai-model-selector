#!/usr/bin/env python3
# /usr/bin/ai-model-selector
import gi
gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')
from gi.repository import Gtk, Adw, GLib
import subprocess, json, threading

class ModelSelector(Adw.Application):
    def __init__(self):
        super().__init__(application_id='org.ash.ai.ModelSelector')
        self.models = []
        
    def do_activate(self):
        win = Adw.ApplicationWindow(application=self, title="AI Model Selector")
        win.set_default_size(600, 500)
        
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.set_margin_top(12); box.set_margin_bottom(12); box.set_margin_start(12); box.set_margin_end(12)
        
        header = Adw.HeaderBar()
        header.set_title_widget(Adw.WindowTitle(title="AI Model Selector", subtitle="Pull & manage Ollama models"))
        win.set_titlebar(header)
        
        self.listbox = Gtk.ListBox()
        self.listbox.set_selection_mode(Gtk.SelectionMode.NONE)
        scrolled = Gtk.ScrolledWindow()
        scrolled.set_child(self.listbox)
        scrolled.set_vexpand(True)
        box.append(scrolled)
        
        btn = Gtk.Button(label="🔄 Refresh")
        btn.connect("clicked", self.on_refresh)
        box.append(btn)
        
        win.set_content(box)
        win.present()
        self.refresh_models()
    
    def refresh_models(self):
        def worker():
            try:
                # Local models
                result = subprocess.run(['ollama', 'list', '--json'], capture_output=True, text=True)
                local = json.loads(result.stdout) if result.stdout else []
                
                # Available models
                result = subprocess.run(['ollama', 'search', '--json', ''], capture_output=True, text=True)
                available = json.loads(result.stdout) if result.stdout else []
                
                GLib.idle_add(self.update_list, local, available)
            except Exception as e:
                GLib.idle_add(self.show_error, str(e))
        threading.Thread(target=worker, daemon=True).start()
    
    def update_list(self, local, available):
        child = self.listbox.get_first_child()
        while child:
            self.listbox.remove(child)
            child = self.listbox.get_first_child()
        
        # Installed
        row = Adw.ActionRow(title="📦 Installed Models", activatable=False)
        row.add_css_class("heading")
        self.listbox.append(row)
        
        for m in local:
            name = m.get('name', 'unknown')
            size = m.get('size', 0) / (1024**3)
            row = Adw.ActionRow(title=name, subtitle=f"{size:.1f} GB")
            btn = Gtk.Button(label="🗑️ Remove")
            btn.connect("clicked", lambda _, n=name: self.remove_model(n))
            row.add_suffix(btn)
            self.listbox.append(row)
        
        # Available
        row = Adw.ActionRow(title="🌐 Available Models (click to pull)", activatable=False)
        row.add_css_class("heading")
        self.listbox.append(row)
        
        for m in available[:20]:
            name = m.get('name', 'unknown')
            desc = m.get('description', '')[:80]
            size = m.get('size', 0) / (1024**3)
            row = Adw.ActionRow(title=name, subtitle=f"{desc} ({size:.1f} GB)")
            btn = Gtk.Button(label="⬇️ Pull")
            btn.connect("clicked", lambda _, n=name: self.pull_model(n))
            row.add_suffix(btn)
            self.listbox.append(row)
    
    def pull_model(self, name):
        def worker():
            proc = subprocess.Popen(['ollama', 'pull', name], stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
            for line in proc.stdout:
                GLib.idle_add(self.show_toast, line.strip())
            proc.wait()
            GLib.idle_add(self.refresh_models)
        threading.Thread(target=worker, daemon=True).start()
    
    def remove_model(self, name):
        subprocess.run(['ollama', 'rm', name])
        self.refresh_models()
    
    def on_refresh(self, _):
        self.refresh_models()
    
    def show_toast(self, msg):
        toast = Adw.Toast.new(msg)
        self.props.active_window.toast_overlay.add_toast(toast)
    
    def show_error(self, msg):
        dialog = Adw.MessageDialog(
            transient_for=self.props.active_window,
            heading="Error",
            body=msg
        )
        dialog.present()

if __name__ == '__main__':
    app = ModelSelector()
    app.run()