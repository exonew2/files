---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((doc) => ({
    params: { slug: doc.slug },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content } = await doc.render();
---
<Layout
  title={`${doc.data.title} — ash Documentation`}
  description={doc.data.description ?? ''}
  ogImage="/og-image.svg"
>
<section class="page-hero">
  <div class="container">
    <p class="breadcrumb"><a href="/docs">Documentation</a> / {doc.data.title}</p>
    <h1>{doc.data.title}</h1>
  </div>
</section>

<section class="section doc-content">
  <div class="container doc-container">
    <Content />
  </div>
</section>
</Layout>

<style>
.breadcrumb {
  font-size: 13px;
  color: var(--text-muted);
  margin-bottom: 8px;
}
.breadcrumb a {
  color: var(--brand);
  text-decoration: none;
}
.breadcrumb a:hover { text-decoration: underline; }
.doc-container {
  max-width: 800px;
  margin: 0 auto;
  line-height: 1.7;
}
.doc-container h2 {
  font-size: 24px;
  font-weight: 700;
  margin-top: 40px;
  margin-bottom: 16px;
  padding-bottom: 8px;
  border-bottom: 1px solid var(--border);
}
.doc-container h3 {
  font-size: 18px;
  font-weight: 600;
  margin-top: 32px;
  margin-bottom: 12px;
}
.doc-container p {
  margin-bottom: 16px;
  color: var(--text-dim);
}
.doc-container code {
  font-family: var(--font-mono);
  background: var(--bg-elevated);
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 0.9em;
}
.doc-container pre {
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px;
  overflow-x: auto;
  margin: 16px 0;
}
.doc-container pre code {
  background: none;
  padding: 0;
  font-size: 13px;
  line-height: 1.6;
}
.doc-container table {
  width: 100%;
  border-collapse: collapse;
  margin: 16px 0;
  font-size: 14px;
}
.doc-container th, .doc-container td {
  padding: 10px 14px;
  border: 1px solid var(--border);
  text-align: left;
}
.doc-container th {
  background: var(--bg-elevated);
  font-weight: 600;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--text-muted);
}
.doc-container ul, .doc-container ol {
  padding-left: 24px;
  margin-bottom: 16px;
  color: var(--text-dim);
}
.doc-container li { margin-bottom: 8px; }
.doc-container a { color: var(--brand); text-decoration: none; }
.doc-container a:hover { text-decoration: underline; }
</style>
